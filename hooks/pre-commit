#!/bin/sh
# Block commits containing secrets (API keys, tokens, credentials).
# Requires betterleaks: brew install betterleaks
# Enabled via: git config core.hooksPath hooks

if ! command -v betterleaks >/dev/null 2>&1; then
  echo "pre-commit: betterleaks not installed (brew install betterleaks) — refusing to commit unscanned." >&2
  exit 1
fi

betterleaks git --staged --pre-commit --redact --verbose
